{
  "name": "quali",
  "version": "1.3.7",
  "description": "Lead Review Tool - Batch Google search and triage leads from Excel",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron src/main/index.js\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:publish:win": "vite build && electron-builder --win --publish always",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.quali.app",
    "productName": "Quali",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "QualiLogo.ico",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "QualiLogo.ico",
        "to": "QualiLogo.ico"
      }
    ],
    "mac": {
      "target": "dmg",
      "icon": "QualiLogo.png",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/ArpitTeli/Quali.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.7.0",
    "recharts": "^3.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
